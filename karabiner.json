{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Disable Cmd+R in Firefox",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^org\\.mozilla\\.firefox$"
                                        ],
                                        "type": "frontmost_application_if"
                                    }
                                ],
                                "from": {
                                    "key_code": "r",
                                    "modifiers": {
                                        "mandatory": ["command"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "vk_none" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Connect Headphones with LCmd-F3",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "f3",
                                    "modifiers": {
                                        "mandatory": ["left_command"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [{ "shell_command": "/opt/homebrew/bin/blueutil --connect 88-c9-e8-f8-6a-08" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Open a terminal window with Ctrl-RCmd-T",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "t",
                                    "modifiers": {
                                        "mandatory": ["left_control", "left_command"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [{ "shell_command": "open -a iTerm ~" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
